{
  "name": "markdown-toolkit",
  "displayName": "Markdown Toolkit",
  "description": "Open Markdown preview in-place or in a detached window with Mermaid rendering and pan/zoom.",
  "version": "1.0.3",
  "publisher": "zhouyuyang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyyziyunying/markdown-toolkit.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "preview",
    "mermaid",
    "diagram",
    "editor",
    "productivity"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownToolkit.openPreviewInPlace",
        "title": "Open Markdown Preview (In Place)",
        "category": "Markdown Toolkit",
        "enablement": "resourceLangId == markdown && activeCustomEditorId != vscode.markdown.preview.editor",
        "icon": "$(book)"
      },
      {
        "command": "markdownToolkit.openFloatingPreview",
        "title": "Open Floating Markdown Preview",
        "shortTitle": "Float Preview",
        "category": "Markdown Toolkit",
        "enablement": "!isAuxiliaryWindow",
        "icon": "$(link-external)"
      },
      {
        "command": "markdownToolkit.exitPreviewInPlace",
        "title": "Exit Markdown Preview (In Place)",
        "category": "Markdown Toolkit",
        "enablement": "!isAuxiliaryWindow && (activeCustomEditorId == vscode.markdown.preview.editor || markdownToolkit.immersiveEnabled)",
        "icon": "$(close)"
      },
      {
        "command": "markdownToolkit.openReadonlyViewer",
        "title": "Open Markdown Readonly Viewer (Experimental)",
        "shortTitle": "Readonly Viewer",
        "category": "Markdown Toolkit",
        "enablement": "config.markdownToolkit.experimental.immersiveReadonlyViewer",
        "icon": "$(preview)"
      },
      {
        "command": "markdownToolkit.switchToSourceEditor",
        "title": "Switch to Markdown Source",
        "shortTitle": "To Source",
        "category": "Markdown Toolkit",
        "enablement": "activeCustomEditorId == markdownToolkit.markdownReadonlyViewer",
        "icon": "$(edit)"
      },
      {
        "command": "markdownToolkit.runImmersiveReadonlyViewerSpikeBenchmark",
        "title": "Run Immersive Readonly Viewer Spike Benchmark (Experimental)",
        "shortTitle": "Run Spike Benchmark",
        "category": "Markdown Toolkit",
        "enablement": "config.markdownToolkit.experimental.immersiveReadonlyViewer",
        "icon": "$(pulse)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownToolkit.openPreviewInPlace",
          "group": "navigation@10",
          "when": "resourceLangId == markdown && activeCustomEditorId != vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.openFloatingPreview",
          "group": "navigation@10.1",
          "when": "!isAuxiliaryWindow && (resourceLangId == markdown || activeCustomEditorId == vscode.markdown.preview.editor)"
        },
        {
          "command": "markdownToolkit.exitPreviewInPlace",
          "group": "navigation@11",
          "when": "!isAuxiliaryWindow && activeCustomEditorId == vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.openReadonlyViewer",
          "group": "navigation@10.2",
          "when": "config.markdownToolkit.experimental.immersiveReadonlyViewer && resourceLangId == markdown && activeCustomEditorId != markdownToolkit.markdownReadonlyViewer"
        },
        {
          "command": "markdownToolkit.switchToSourceEditor",
          "group": "navigation@11.1",
          "when": "activeCustomEditorId == markdownToolkit.markdownReadonlyViewer"
        }
      ],
      "editor/context": [
        {
          "command": "markdownToolkit.openPreviewInPlace",
          "group": "navigation@10",
          "when": "resourceLangId == markdown && activeCustomEditorId != vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.openFloatingPreview",
          "group": "navigation@10.1",
          "when": "!isAuxiliaryWindow && (resourceLangId == markdown || activeCustomEditorId == vscode.markdown.preview.editor)"
        },
        {
          "command": "markdownToolkit.exitPreviewInPlace",
          "group": "navigation@11",
          "when": "!isAuxiliaryWindow && activeCustomEditorId == vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.openReadonlyViewer",
          "group": "navigation@10.2",
          "when": "config.markdownToolkit.experimental.immersiveReadonlyViewer && resourceLangId == markdown && activeCustomEditorId != markdownToolkit.markdownReadonlyViewer"
        },
        {
          "command": "markdownToolkit.switchToSourceEditor",
          "group": "navigation@11.1",
          "when": "activeCustomEditorId == markdownToolkit.markdownReadonlyViewer"
        }
      ],
      "webview/context": [
        {
          "command": "markdownToolkit.openFloatingPreview",
          "group": "navigation@10.1",
          "when": "!isAuxiliaryWindow && activeCustomEditorId == vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.exitPreviewInPlace",
          "group": "navigation@11",
          "when": "!isAuxiliaryWindow && activeCustomEditorId == vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.switchToSourceEditor",
          "group": "navigation@11.1",
          "when": "activeCustomEditorId == markdownToolkit.markdownReadonlyViewer"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownToolkit.openReadonlyViewer",
          "group": "navigation@10.2",
          "when": "config.markdownToolkit.experimental.immersiveReadonlyViewer && resourceExtname == .md"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownToolkit.openPreviewInPlace",
          "when": "resourceLangId == markdown && activeCustomEditorId != vscode.markdown.preview.editor"
        },
        {
          "command": "markdownToolkit.openFloatingPreview",
          "when": "!isAuxiliaryWindow && (resourceLangId == markdown || activeCustomEditorId == vscode.markdown.preview.editor)"
        },
        {
          "command": "markdownToolkit.exitPreviewInPlace",
          "when": "!isAuxiliaryWindow && (activeCustomEditorId == vscode.markdown.preview.editor || markdownToolkit.immersiveEnabled)"
        },
        {
          "command": "markdownToolkit.openReadonlyViewer",
          "when": "config.markdownToolkit.experimental.immersiveReadonlyViewer"
        },
        {
          "command": "markdownToolkit.switchToSourceEditor",
          "when": "activeCustomEditorId == markdownToolkit.markdownReadonlyViewer"
        },
        {
          "command": "markdownToolkit.runImmersiveReadonlyViewerSpikeBenchmark",
          "when": "config.markdownToolkit.experimental.immersiveReadonlyViewer"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "command": "markdownToolkit.openPreviewInPlace",
        "when": "editorTextFocus && resourceLangId == markdown"
      },
      {
        "key": "ctrl+alt+shift+m",
        "mac": "cmd+alt+shift+m",
        "command": "markdownToolkit.openFloatingPreview",
        "when": "!isAuxiliaryWindow && ((editorTextFocus && resourceLangId == markdown) || activeCustomEditorId == vscode.markdown.preview.editor)"
      }
    ],
    "customEditors": [
      {
        "viewType": "markdownToolkit.markdownReadonlyViewer",
        "displayName": "Markdown Readonly Viewer (Experimental)",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Markdown Toolkit",
      "properties": {
        "markdownToolkit.experimental.immersiveReadonlyViewer": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "[Experimental] Open `*.md` with `markdownToolkit.markdownReadonlyViewer`; turning this off restores previous editor association."
        }
      }
    },
    "markdown.previewScripts": [
      "./media/mermaid.min.js",
      "./media/mermaidFocusMode.js",
      "./media/mermaidInteraction.js",
      "./media/mermaidRenderer.js",
      "./media/mermaidPreview.js"
    ],
    "markdown.previewStyles": [
      "./media/mermaidPreview.css"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
